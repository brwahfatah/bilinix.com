# ── WHMCS API credentials (server-side only) ──────────────────────────────────
NUXT_WHMCS_API_URL=https://your-whmcs.tld/includes/api.php
NUXT_WHMCS_API_IDENTIFIER=your_api_identifier
NUXT_WHMCS_API_SECRET=your_api_secret
NUXT_WHMCS_ACCESS_KEY=
# Min 32 random characters — used to sign session tokens
NUXT_WHMCS_TOKEN_SECRET=replace-with-a-long-random-secret-min-32-chars

# ── WHMCS department IDs — set to match your actual WHMCS departments ─────────
NUXT_WHMCS_DEPT_TECHNICAL=1
NUXT_WHMCS_DEPT_BILLING=2
NUXT_WHMCS_DEPT_SALES=3
NUXT_WHMCS_DEPT_GENERAL=4

# ── NOWPayments (server-only) ─────────────────────────────────────────────────
NUXT_NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NUXT_NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret

# ── Public runtime config ─────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE=/api/whmcs
NUXT_PUBLIC_APP_ENV=production
NUXT_PUBLIC_ENABLE_DEV_MOCKS=false
# Payment feature flags — set to false to disable a provider
NUXT_PUBLIC_ENABLE_STRIPE=false
NUXT_PUBLIC_ENABLE_NOWPAYMENTS=true
